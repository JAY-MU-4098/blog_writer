# Required: OpenAI API key for blog generation
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: OpenAI model (default: gpt-4.1-mini)
OPENAI_MODEL=gpt-4.1-mini

# Optional: Tavily API key for web research (when goal=authority or topic needs stats)
TAVILY_API_KEY=

# Optional: Resend API key to send the blog as email
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional: Quality threshold 1-10; if score below this, SEO step is retried (default: 7)
BLOG_QUALITY_THRESHOLD=7

# Optional: Log level (default: INFO)
LOG_LEVEL=INFO
